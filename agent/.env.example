# Copy this file to  agent/.env  and fill in your key. agent/.env is git-ignored.
#
#   cp agent/.env.example agent/.env
#   # then edit agent/.env

OPENAI_API_KEY=sk-your-key-here

# Optional overrides (defaults shown)
OPENAI_MODEL=gpt-4o

# --- Run on a local / free model instead of hosted OpenAI ---
# Point at any OpenAI-compatible endpoint and no OpenAI key is needed (leave OPENAI_API_KEY blank).
# Example with Ollama (https://ollama.com):
#   1. ollama pull llama3.1
#   2. uncomment the two lines below
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3.1
